# GitHub integration for the Task Tracker (commits task Markdown to the repo).
# Copy to .env.local for local dev, and set the same variables in the Vercel
# project settings for production. Never commit real tokens.
#
# The token needs write access to the repository contents (Contents: Read and
# write for a fine-grained PAT, or the "repo" scope for a classic PAT).

GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=mvest2019
GITHUB_REPO=mineral_view_governance_workbench
GITHUB_BRANCH=Development

# ---------------------------------------------------------------------------
# MongoDB (Phase 1 — connection foundation only; GitHub storage stays the
# source of truth). The connection layer targets ONLY the GovernanceDB database
# on the MView-Staging cluster and never touches any other database.
#
# MONGODB_URI is a secret — put the real value in .env.local (git-ignored) and
# in the Vercel project settings. Never commit a real connection string.
# ---------------------------------------------------------------------------

# Full MView-Staging connection string (required to enable the MongoDB layer).
MONGODB_URI=mongodb+srv://<user>:<password>@<host>/?retryWrites=true&w=majority

# Target database. Defaults to GovernanceDB if unset. Do not point this at any
# other database in the cluster.
MONGODB_DB_NAME=GovernanceDB

# Optional connection-pool tuning (sensible defaults are applied when unset).
# MONGODB_MAX_POOL_SIZE=10
# MONGODB_MIN_POOL_SIZE=0
# MONGODB_MAX_IDLE_TIME_MS=60000
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
