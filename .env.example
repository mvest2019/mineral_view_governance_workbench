# GitHub integration for the Task Tracker (commits task Markdown to the repo).
# Copy to .env.local for local dev, and set the same variables in the Vercel
# project settings for production. Never commit real tokens.
#
# The token needs write access to the repository contents (Contents: Read and
# write for a fine-grained PAT, or the "repo" scope for a classic PAT).

GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=mvest2019
GITHUB_REPO=mineral_view_governance_workbench
GITHUB_BRANCH=Development
