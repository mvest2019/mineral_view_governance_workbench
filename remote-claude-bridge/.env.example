# Remote Claude bridge configuration.
# Copy to .env next to server.js; start-claude-bridge.bat loads it automatically.

# REQUIRED: shared secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The Vercel app must send the same value as REMOTE_CLAUDE_TOKEN.
CLAUDE_BRIDGE_TOKEN=

# Listen port / bind address.
# Keep HOST=127.0.0.1 when using a tunnel (Cloudflare Tunnel, ngrok) running on
# the same machine. Use 0.0.0.0 only when a reverse proxy on another host
# terminates HTTPS in front of the bridge.
CLAUDE_BRIDGE_PORT=8787
CLAUDE_BRIDGE_HOST=127.0.0.1

# Optional: explicit path to the Claude CLI. Usually unnecessary — the bridge
# resolves `claude` from PATH (preferring claude.exe, and unwrapping npm's
# claude.cmd shim to its cli.js automatically). Examples:
#   CLAUDE_BRIDGE_CLAUDE_EXE=C:\Users\Realizer\.local\bin\claude.exe
#   CLAUDE_BRIDGE_CLAUDE_EXE=C:\Users\Realizer\AppData\Roaming\npm\node_modules\@anthropic-ai\claude-code\cli.js
CLAUDE_BRIDGE_CLAUDE_EXE=

# Optional: working directory used when a request's cwd does not exist on this
# machine (defaults to the bridge directory).
CLAUDE_BRIDGE_DEFAULT_CWD=

# Optional: rewrite paths sent by the deployed app (cwd and --add-dir values)
# to the equivalent local paths on this machine. Format: from=>to pairs
# separated by |. Longest prefix wins. Example for a Vercel deployment whose
# repo is checked out at C:\repos\mineral_view_governance_workbench:
#   CLAUDE_BRIDGE_PATH_MAP=/var/task=>C:\repos\mineral_view_governance_workbench
CLAUDE_BRIDGE_PATH_MAP=

# Optional tuning.
CLAUDE_BRIDGE_MAX_CONCURRENCY=4
CLAUDE_BRIDGE_MAX_TIMEOUT_MS=1800000
CLAUDE_BRIDGE_MAX_BODY_BYTES=33554432

# Optional: serve HTTPS directly (must be a publicly trusted certificate for
# Vercel to connect; a Cloudflare Tunnel is usually simpler).
CLAUDE_BRIDGE_TLS_CERT_FILE=
CLAUDE_BRIDGE_TLS_KEY_FILE=
